# --- LLM y embeddings ---
OLLAMA_URL=http://localhost:11434/api
LLM_MODEL=gemma3:4b
EMBED_MODEL=nomic-embed-text

# --- Backends (intercambiabilidad hexagonal) ---
# Cambiar adapter = cambiar 1 línea aquí
LLM_BACKEND=ollama          # ollama | poligpt
EMBEDDER_BACKEND=ollama     # ollama | st
RETRIEVER_BACKEND=chroma    # chroma | faiss

# --- PoliGPT (requiere VPN UPV) ---
# POLIGPT_API_KEY=<tu_clave_aquí>
# POLIGPT_BASE_URL=https://api.poligpt.upv.es/v1
# POLIGPT_MODEL=poligpt

# --- Vector store ---
COLLECTION_NAME=dni_valencia
# CHROMA_PATH y FAISS_PATH se calculan automáticamente desde la raíz

# --- SSL ---
VERIFY_SSL=true
# Si tiramos contra el endpoint UPV (cert autofirmado):
# VERIFY_SSL=false

# --- API (opción B del contrato) ---
API_HOST=127.0.0.1
API_PORT=8000
